<div class="profile-field {{#if error}}error{{/if}}">
  <label for="{{id}}">
    {{label}}
  </label>
  {{#if disabled}}
  <input disabled {{#if value}}value={{value}}{{/if}} >
  {{else}}
  <input type={{type}} for={{id}} name={{name}} required pattern={{pattern}} {{#if value}}value={{value}}{{/if}} >
{{/if}}
  {{#if error}} <div class="errorText">{{errorText}}</div>{{/if}}
</div>
